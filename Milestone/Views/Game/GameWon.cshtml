@model Milestone.Models.GameResultViewModel
@{
    ViewData["Title"] = "Game Won";
    var minutes = (int)Model.Elapsed.TotalMinutes;
    var seconds = Model.Elapsed.Seconds;
}

<div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 60vh;">
    <h1 class="text-success mb-4">GAME WON</h1>

    <div class="d-flex flex-column align-items-center gap-2">
        <p class="fs-5 mb-0">Time: @minutes:@seconds.ToString("D2")</p>
        <p class="fs-5 mb-0">Score: @Model.Score</p>
    </div>

    <div class="d-flex gap-2 mt-4">
        <a asp-controller="Game" asp-action="NewGame" class="btn btn-primary">Play Again</a>
        <a asp-controller="Home" asp-action="Menu" class="btn btn-secondary">Menu</a>
    </div>
</div>
